<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <%- include('partials/head') %>
</head>
<body>

    <%- include('partials/header') %>

    <main class="auth-page container">
        <section class="auth-card">
            <h1>Вход</h1>

            <% if (flash) { %>
                <div class="alert alert-<%= flash.type %>" role="alert"><%= flash.message %></div>
            <% } %>

            <% if (errors.form) { %>
                <div class="alert alert-error" role="alert"><%= errors.form %></div>
            <% } %>

            <form class="auth-form" action="/login" method="POST" data-auth-form="login" novalidate>
                <% if (returnUrl) { %>
                    <input type="hidden" name="returnUrl" value="<%= returnUrl %>">
                <% } %>

                <div class="form-group<%= errors.email ? ' has-error' : '' %>">
                    <input
                        type="email"
                        id="email"
                        name="email"
                        value="<%= values.email %>"
                        placeholder="Email"
                        autocomplete="email"
                        aria-label="Email"
                        required
                        maxlength="255"
                    >
                    <% if (errors.email) { %>
                        <span class="field-error"><%= errors.email %></span>
                    <% } %>
                </div>

                <div class="form-group<%= errors.password ? ' has-error' : '' %>">
                    <input
                        type="password"
                        id="password"
                        name="password"
                        placeholder="Пароль"
                        autocomplete="current-password"
                        aria-label="Пароль"
                        required
                        maxlength="128"
                    >
                    <% if (errors.password) { %>
                        <span class="field-error"><%= errors.password %></span>
                    <% } %>
                    <p class="auth-forgot">
                        <a href="/forgot-password">Забыли пароль?</a>
                    </p>
                </div>

                <button type="submit" class="btn-primary btn-full">Войти</button>
            </form>

            <p class="auth-footer">
                Нет аккаунта? <a href="/register">Зарегистрироваться</a>
            </p>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="/js/auth-validation.js"></script>
    <script src="/js/login.js"></script>
</body>
</html>
