<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <%- include('partials/head') %>
</head>
<body>

    <%- include('partials/header') %>

    <main class="auth-page container">
        <section class="auth-card">
            <h1>Новый пароль</h1>

            <% if (!token) { %>
                <% if (errors.form) { %>
                    <div class="alert alert-error" role="alert"><%= errors.form %></div>
                <% } %>
                <p class="auth-footer">
                    <a href="/forgot-password">Запросить восстановление снова</a>
                </p>
            <% } else { %>
                <p class="auth-subtitle">Задайте новый пароль для аккаунта <strong><%= email %></strong></p>

                <% if (errors.form) { %>
                    <div class="alert alert-error" role="alert"><%= errors.form %></div>
                <% } %>

                <form class="auth-form" action="/reset-password/<%= token %>" method="POST">
                    <div class="form-group<%= errors.password ? ' has-error' : '' %>">
                        <input
                            type="password"
                            id="password"
                            name="password"
                            placeholder="Новый пароль"
                            autocomplete="new-password"
                            aria-label="Новый пароль"
                            required
                            minlength="8"
                        >
                        <% if (errors.password) { %>
                            <span class="field-error"><%= errors.password %></span>
                        <% } %>
                    </div>

                    <div class="form-group<%= errors.password_confirm ? ' has-error' : '' %>">
                        <input
                            type="password"
                            id="password_confirm"
                            name="password_confirm"
                            placeholder="Подтвердите пароль"
                            autocomplete="new-password"
                            aria-label="Подтвердите пароль"
                            required
                            minlength="8"
                        >
                        <% if (errors.password_confirm) { %>
                            <span class="field-error"><%= errors.password_confirm %></span>
                        <% } %>
                    </div>

                    <button type="submit" class="btn-primary btn-full">Сохранить пароль</button>
                </form>

                <p class="auth-footer">
                    <a href="/login">Вернуться ко входу</a>
                </p>
            <% } %>
        </section>
    </main>

    <%- include('partials/footer') %>

</body>
</html>
