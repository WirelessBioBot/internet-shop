<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <%- include('partials/head') %>
</head>
<body>

    <%- include('partials/header') %>

    <main class="auth-page container">
        <section class="auth-card">
            <h1>Восстановление пароля</h1>

            <% if (message) { %>
                <div class="alert alert-success" role="status"><%= message %></div>
                <p class="auth-footer">
                    <a href="/login">Вернуться ко входу</a>
                </p>
            <% } else { %>
                <p class="auth-subtitle">Введите email, указанный при регистрации. Мы отправим ссылку для смены пароля.</p>

                <% if (errors.form) { %>
                    <div class="alert alert-error" role="alert"><%= errors.form %></div>
                <% } %>

                <form class="auth-form" action="/forgot-password" method="POST">
                    <div class="form-group<%= errors.email ? ' has-error' : '' %>">
                        <input
                            type="email"
                            id="email"
                            name="email"
                            value="<%= values.email %>"
                            placeholder="Email"
                            autocomplete="email"
                            aria-label="Email"
                            required
                            maxlength="255"
                        >
                        <% if (errors.email) { %>
                            <span class="field-error"><%= errors.email %></span>
                        <% } %>
                    </div>

                    <button type="submit" class="btn-primary btn-full">Отправить ссылку</button>
                </form>

                <p class="auth-footer">
                    Вспомнили пароль? <a href="/login">Войти</a>
                </p>
            <% } %>
        </section>
    </main>

    <%- include('partials/footer') %>

</body>
</html>
